# Set these as environment variables on the server / Docker container.
# .NET uses double-underscore (__) for nested config keys.

MongoDB__ConnectionString=mongodb://mongo:27017
MongoDB__DatabaseName=kattral_academy

Jwt__Secret=YOUR_JWT_SECRET
Jwt__Issuer=kattral-api
Jwt__ExpiryHours=720

LiveKit__ApiKey=YOUR_LIVEKIT_API_KEY
LiveKit__ApiSecret=YOUR_LIVEKIT_API_SECRET
LiveKit__Url=wss://katral-zonddr6x.livekit.cloud

Google__ClientId=YOUR_GOOGLE_CLIENT_ID

PlugNmeet__ApiKey=plugnmeet
PlugNmeet__ApiSecret=YOUR_PLUGNMEET_API_SECRET
PlugNmeet__Url=http://plugnmeet:8080

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5261
